# EU DPP Platform - Environment variables
# Copy to .env and set values. Never commit .env.

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000

# Neo4j 5.x
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/your-password
NEO4J_PORT=7687
NEO4J_HTTP_PORT=7474

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333

# PostgreSQL 16 (asyncpg URL)
POSTGRES_USER=dpp
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=dpp_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dpp:change-me-in-production@localhost:5432/dpp_platform

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
SCHEMA_REGISTRY_URL=http://localhost:8081

# Auth (OAuth2 / JWT - Sprint 3)
SECRET_KEY=generate-a-secure-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Providers
# Anthropic (Claude Sonnet 4 / Opus 4) — primary for regulatory analysis
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (GPT-4o) — general reasoning + embeddings for GraphRAG
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Hugging Face — open-source models, cost-effective inference
HUGGINGFACE_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# EU AI Act compliance
AUDIT_RETENTION_YEARS=10
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.85
